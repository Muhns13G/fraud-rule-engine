{
  "info": {
    "_postman_id": "b180d205-bca8-4ae9-9cfd-f98f4fde78b5",
    "name": "Fraud Rule Engine - Reviewer Checks",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Reviewer-friendly smoke checks for actuator visibility and fraud evaluation API behavior. Uses normalized enums with aliases: channel POS->CARD_PRESENT, ECOM->ONLINE; transactionType CARD_PAYMENT->PAYMENT, CASH_WITHDRAWAL->WITHDRAWAL; merchantCategory MONEYTRANSFER->MONEY_TRANSFER. eventTimestamp must include timezone offset."
  },
  "auth": {
    "type": "basic",
    "basic": [
      {
        "key": "username",
        "value": "{{reviewer_user}}",
        "type": "string"
      },
      {
        "key": "password",
        "value": "{{reviewer_password}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Actuator",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "actuator",
                "health"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Health responds 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Health status is UP', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('UP');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/info",
              "host": [
