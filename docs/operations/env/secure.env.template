# Secure profile template (authenticated local/non-local baseline)
# Usage:
#   cp docs/operations/env/secure.env.template .env.secure
#   export $(grep -v '^#' .env.secure | xargs)

SPRING_PROFILES_ACTIVE=secure

# Hosted datasource contract (required for Railway/Render/non-local runtime):
# Railway usually injects PGHOST/PGPORT/PGDATABASE/PGUSER/PGPASSWORD when
# your app service is linked to a PostgreSQL service.
SPRING_DATASOURCE_URL=jdbc:postgresql://${PGHOST}:${PGPORT}/${PGDATABASE}
SPRING_DATASOURCE_USERNAME=${PGUSER}
SPRING_DATASOURCE_PASSWORD=${PGPASSWORD}

# Identity and secret source
FRAUD_ENGINE_SECURE_IDENTITY_PROVIDER=IN_MEMORY
FRAUD_ENGINE_SECURE_SECRET_SOURCE=ENV
FRAUD_ENGINE_SECURE_USER=secure-user
FRAUD_ENGINE_SECURE_PASSWORD=change-me-secure
# FRAUD_ENGINE_SECURE_PASSWORD_ENCODED=
# FRAUD_ENGINE_SECURE_EXTERNAL_SECRET_REF=
# FRAUD_ENGINE_SECURE_EXTERNAL_MANAGER_ADAPTER=ENV
# Example for external-manager adapter:
# FRAUD_ENGINE_SECURE_EXTERNAL_SECRET_REF=env:FRAUD_ENGINE_SECURE_SECRET_PAYLOAD
# FRAUD_ENGINE_SECURE_SECRET_PAYLOAD={"username":"secure-user","passwordEncoded":"<bcrypt hash>"}

# Role contract (must be distinct)
FRAUD_ENGINE_SECURE_ROLE=API_CLIENT
FRAUD_ENGINE_SECURE_OPS_READER_ROLE=OPS_READER
FRAUD_ENGINE_SECURE_ADMIN_ROLE=GOVERNANCE_ADMIN
FRAUD_ENGINE_SECURE_PLATFORM_ADMIN_ROLE=PLATFORM_ADMIN

# Secure observability/docs posture
FRAUD_ENGINE_SECURE_ACTUATOR_EXPOSURE=health,info
FRAUD_ENGINE_SECURE_SWAGGER_UI_ENABLED=false
FRAUD_ENGINE_SECURE_API_DOCS_ENABLED=false

# Rotation lifecycle (optional)
# Safe sequence: PREPARE -> OVERLAP -> CUTOVER -> RETIRE
# FRAUD_ENGINE_SECURE_ROTATION_PHASE=PREPARE
# FRAUD_ENGINE_SECURE_ROTATION_PHASE=OVERLAP
# FRAUD_ENGINE_SECURE_ROTATION_PHASE=CUTOVER
# FRAUD_ENGINE_SECURE_ROTATION_PHASE=RETIRE
# Legacy compatibility (discouraged): if phase is omitted and rotation-enabled=true, runtime defaults to OVERLAP.
FRAUD_ENGINE_SECURE_ROTATION_ENABLED=false
# FRAUD_ENGINE_SECURE_ROTATION_USER=
# FRAUD_ENGINE_SECURE_ROTATION_PASSWORD=
# FRAUD_ENGINE_SECURE_ROTATION_PASSWORD_ENCODED=
